    private Font createTamilFont(float size) throws IOException, DocumentException {

        ClassPathResource fontResource = new ClassPathResource("fonts/Latha.ttf");
        try (InputStream inputStream = fontResource.getInputStream()) {
            byte[] fontBytes = inputStream.readAllBytes();
            BaseFont baseFont = BaseFont.createFont(
                    "Latha",
                    BaseFont.IDENTITY_H,
                    BaseFont.EMBEDDED,
                    true,
                    fontBytes,
                    null
            );
            return new Font(baseFont, size);
        }
    }

    private void addRow(PdfPTable table, String label, String value, Font font) {

        PdfPCell cell1 = new PdfPCell(new Paragraph(label, font));
        PdfPCell cell2 = new PdfPCell(new Paragraph(value != null ? value : "", font));

        table.addCell(cell1);
        table.addCell(cell2);
    }
    
