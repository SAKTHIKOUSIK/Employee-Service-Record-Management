@Service
public class EmployeeReportService {

    private final EmployeeRepository employeeRepository;

    public EmployeeReportService(EmployeeRepository employeeRepository) {
        this.employeeRepository = employeeRepository;
    }

    public byte[] generateEmployeeReport(Long id) {

        Employee employee = employeeRepository.findById(id)
                .orElseThrow(() -> new EmployeeNotFoundException("Employee not found with id: " + id));

        try (ByteArrayOutputStream baos = new ByteArrayOutputStream()) {

            Document document = new Document(PageSize.A4);
            PdfWriter.getInstance(document, baos);
            document.open();

            // English font
            Font titleFont = FontFactory.getFont(FontFactory.HELVETICA_BOLD, 16);
            Font normalFont = FontFactory.getFont(FontFactory.HELVETICA, 12);

            // Tamil font – load from classpath
//            Font tamilFont = createTamilFont(16);
            
            Font tamilFont = createTamilFont(16);
            Font tamilNormalFont = createTamilFont(12);

            // Titles
            document.add(new Paragraph("Employee Service Record Report", titleFont));
            document.add(new Paragraph(" ", normalFont)); // empty line

//            document.add(new Paragraph("பணியாளர் சேவை விவர அறிக்கை", tamilFont));
//            document.add(new Paragraph(" ", normalFont)); // empty line
            
            document.add(new Paragraph("பணியாளர் சேவை விவர அறிக்கை", tamilFont));
            document.add(new Paragraph(" ", normalFont));
            

            // Table with fields
            PdfPTable table = new PdfPTable(2);
            table.setWidthPercentage(100);

            addRow(table, "Employee Code", employee.getEmployeeCode(), normalFont);
            addRow(table, "Employee Name (English)", employee.getEmployeeNameEnglish(), normalFont);
            addRow(table, "Employee Name (Tamil)", employee.getEmployeeNameTamil(), tamilFont);
            addRow(table, "Employee Name (Tamil)", employee.getEmployeeNameTamil(), tamilNormalFont);
            addRow(table, "Designation", employee.getDesignation(), normalFont);
            addRow(table, "Department", employee.getDepartment(), normalFont);
            addRow(table, "Date of Joining", employee.getDateOfJoining() != null ? employee.getDateOfJoining().toString() : "", normalFont);
            addRow(table, "Mobile Number", employee.getMobileNumber(), normalFont);
            addRow(table, "Email", employee.getEmail(), normalFont);
            addRow(table, "Remarks", employee.getRemarks(), normalFont);

            document.add(table);
            document.close();

            return baos.toByteArray();
        } catch (DocumentException | IOException ex) {
            throw new RuntimeException("Failed to generate employee report PDF", ex);
        }
    }

